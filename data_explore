#%%
import pandas as pd

df = pd.read_csv("data.csv")

# Basic info
print("SHAPE:", df.shape)
print("\nCOLUMNS:\n", df.columns.tolist())

# dtypes and non-null counts
print("\nINFO:")
print(df.info())

# First and last rows
print("\nHEAD:")
print(df.head(10).to_string(index=False))
print("\nTAIL:")
print(df.tail(10).to_string(index=False))

# Summary statistics for numeric cols
print("\nNUMERIC DESCRIPTION:")
print(df.describe(include=["number"]).T)

# Summary for object/categorical columns
obj = df.select_dtypes(include=["object", "category"])
if not obj.empty:
    print("\nTOP VALUE COUNTS FOR CATEGORICAL COLUMNS:")
    for c in obj.columns:
        print(f"\n-- {c} --")
        print(obj[c].value_counts(dropna=False).head(10).to_string())

# Missing values
print("\nMISSING VALUES (per column):")
print(df.isna().sum())

# If there's a likely target column (named 'label' or 'target'), show distribution
for candidate in ("label", "target", "y", "class"):
    if candidate in df.columns:
        print(f"\nDISTRIBUTION OF '{candidate}':")
        print(df[candidate].value_counts(dropna=False))
        break

print("\nDone.")
